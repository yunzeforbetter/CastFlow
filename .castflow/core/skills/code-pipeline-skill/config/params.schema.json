{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Code Pipeline Runtime Decisions (L1)",
  "type": "object",
  "properties": {
    "execution_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Step1", "Step2", "Step3", "Step4", "Step5", "Step6", "Step7", "Step8", "Step9"]
      },
      "description": "Steps to execute. Step1/3/4/5/9 are required, others are optional.",
      "default": ["Step1", "Step3", "Step4", "Step5", "Step9"]
    },
    "context_retention": {
      "type": "string",
      "enum": ["Cleanup", "Persist"],
      "default": "Cleanup",
      "description": "Whether to delete or keep the PIPELINE_CONTEXT.md after completion."
    }
  },
  "required": ["execution_steps"],
  "additionalProperties": false
}
